{
  "expo": {
    "name": "SRV Electricals",
    "slug": "srv-electricals",
    "scheme": "srv-electricals",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#F5F0E8"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F5F0E8"
      }
    },
    "web": {
      "bundler": "metro"
    }
  }
}
