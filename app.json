{
  "expo": {
    "name": "SRV Electricals",
    "slug": "srv-electricals",
    "scheme": "srv-electricals",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#F5F0E8"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "SRV uses your current location to auto-fill your state, city, and pincode during signup."
      }
    },
    "android": {
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#F5F0E8"
      }
    },
    "web": {
      "bundler": "metro"
    }
  }
}
